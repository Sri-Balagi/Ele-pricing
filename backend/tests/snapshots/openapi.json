  "components": {
    "schemas": {
      "APISuccessEnvelope": {
        "properties": {
          "success": {
            "type": "boolean",
            "title": "Success",
            "default": true
          },
          "data": {
            "title": "Data"
          },
          "correlation_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Correlation Id"
          },
          "timestamp": {
            "type": "string",
            "title": "Timestamp"
          }
        },
        "type": "object",
        "required": [
          "data",
          "timestamp"
        ],
        "title": "APISuccessEnvelope",
        "description": "Standardized API Success Response Envelope."
      },
      "CreateConfigurationRequest": {
        "properties": {
          "customer_reference": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
