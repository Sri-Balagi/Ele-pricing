  "components": {
    "schemas": {
      "APISuccessEnvelope": {
        "properties": {
          "success": {
            "type": "boolean",
            "title": "Success",
            "default": true
          },
          "data": {
            "title": "Data"
          },
          "correlation_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Correlation Id"
          },
          "timestamp": {
            "type": "string",
            "title": "Timestamp"
          }
        },
        "type": "object",
        "required": [
          "data",
          "timestamp"
        ],
        "title": "APISuccessEnvelope",
        "description": "Standardized API Success Response Envelope."
      },
      "CreateConfigurationRequest": {
        "properties": {
          "project_name": {
            "type": "string",
            "minLength": 1,
            "title": "Project Name",
            "description": "Customer-given project name (e.g. 'My Apartment')"
          },
          "customer_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Customer Name",
            "description": "Project-in Charge / Customer Name"
          },
          "selected_category": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Selected Category",
            "description": "The chosen ElevatorCategory ID"
          },
          "customer_reference": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Customer Reference",
            "description": "Deprecated: Optional CRM/ERP reference ID"
          }
        },
        "type": "object",
        "required": [
          "project_name"
        ],
        "title": "CreateConfigurationRequest",
        "description": "Payload for starting a new configuration session."
      },
      "DetailedHealthResponse": {
        "properties": {
          "status": {
            "$ref": "#/components/schemas/HealthStatus"
          },
          "version": {
            "type": "string",
            "title": "Version"
          },
          "environment": {
            "type": "string",
            "title": "Environment"
          },
          "uptime_seconds": {
            "type": "number",
            "title": "Uptime Seconds"
          },
          "data_initialized": {
            "type": "boolean",
            "title": "Data Initialized"
          },
          "data_files": {
            "additionalProperties": {
              "type": "boolean"
            },
            "type": "object",
            "title": "Data Files"
          },
          "pipeline_ready": {
            "type": "boolean",
            "title": "Pipeline Ready"
          },
          "engine_reports": {
            "items": {},
            "type": "array",
            "title": "Engine Reports"
          }
        },
        "type": "object",
        "required": [
          "status",
          "version",
          "environment",
          "uptime_seconds",
          "data_initialized",
          "pipeline_ready"
        ],
        "title": "DetailedHealthResponse",
        "description": "Detailed diagnostics combining data and engine state."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthStatus": {
        "type": "string",
        "enum": [
          "healthy",
          "degraded",
          "unhealthy"
        ],
        "title": "HealthStatus"
      },
      "ReadinessResponse": {
        "properties": {
          "status": {
            "$ref": "#/components/schemas/HealthStatus"
          },
          "ready": {
            "type": "boolean",
            "title": "Ready"
          }
        },
        "type": "object",
        "required": [
          "status",
          "ready"
        ],
        "title": "ReadinessResponse",
        "description": "Simple readiness probe."
      },
      "RuntimeMetrics": {
        "properties": {
          "uptime_seconds": {
            "type": "number",
            "title": "Uptime Seconds"
          },
          "total_requests_processed": {
            "type": "integer",
            "title": "Total Requests Processed",
            "default": 0
          },
          "pipeline_executions": {
            "type": "integer",
            "title": "Pipeline Executions",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "uptime_seconds"
        ],
        "title": "RuntimeMetrics"
      },
      "StartupMetrics": {
        "properties": {
          "application_startup_duration_ms": {
            "type": "number",
            "title": "Application Startup Duration Ms"
          },
          "repository_initialization_ms": {
            "type": "number",
            "title": "Repository Initialization Ms"
          },
          "registry_initialization_ms": {
            "type": "number",
            "title": "Registry Initialization Ms"
          },
          "pipeline_initialization_ms": {
            "type": "number",
            "title": "Pipeline Initialization Ms"
          }
        },
        "type": "object",
        "required": [
          "application_startup_duration_ms",
          "repository_initialization_ms",
          "registry_initialization_ms",
          "pipeline_initialization_ms"
        ],
        "title": "StartupMetrics"
      },
      "SystemPipelineResponse": {
        "properties": {
          "registered_engines": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Registered Engines"
          },
          "catalogue_version": {
            "type": "string",
            "title": "Catalogue Version"
          },
          "schema_version": {
            "type": "string",
            "title": "Schema Version"
          },
          "startup_timestamp": {
            "type": "string",
            "title": "Startup Timestamp"
          },
          "ready": {
            "type": "boolean",
            "title": "Ready"
          },
          "startup_metrics": {
            "$ref": "#/components/schemas/StartupMetrics"
          },
          "runtime_metrics": {
            "$ref": "#/components/schemas/RuntimeMetrics"
          }
        },
        "type": "object",
        "required": [
